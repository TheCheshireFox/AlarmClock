<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:AlarmClock.Views"
             xmlns:vm="clr-namespace:AlarmClock.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:TimePickerViewModel"
             x:Class="AlarmClock.Views.TimePickerView">
    <Design.DataContext>
        <vm:TimePickerViewModel/>
    </Design.DataContext>
    
    <Grid ColumnDefinitions="*,80,*" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
        <views:NumberPickerView Grid.Column="0"
                                 Name="HoursPicker"
                                 DataContext="{Binding HoursPicker}"
                                 ContentHeight="160"
                                 FontSize="160"
                                 FontFamily="{StaticResource LcdFont}"
                                 HorizontalAlignment="Right"/>
        
        <TextBlock Grid.Column="1"
                   Height="160" 
                   LineHeight="160" 
                   FontSize="160" 
                   FontFamily="{StaticResource LcdFont}" 
                   HorizontalAlignment="Center">:</TextBlock>
        
        <views:NumberPickerView Grid.Column="2"
                                 Name="MinutesPicker" 
                                 DataContext="{Binding MinutesPicker}"
                                 ContentHeight="160"
                                 FontSize="160"
                                 FontFamily="{StaticResource LcdFont}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"/>
    </Grid>
</UserControl>
