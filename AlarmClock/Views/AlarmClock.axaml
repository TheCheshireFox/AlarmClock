<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:AlarmClock.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:AlarmClock.ViewModels"
             xmlns:conv="clr-namespace:AlarmClock.Converters"
             x:DataType="vm:AlarmClockViewModel"
             x:Class="AlarmClock.Views.AlarmClockView">
    <Design.DataContext>
        <vm:AlarmClockViewModel/>
    </Design.DataContext>
    
    <UserControl.Resources>
        <conv:TimeSpanToTimeConverter x:Key="TimeSpanConverter"/>
        <conv:AlarmClockStateToButtonTextConverter x:Key="StateTextConverter"/>
    </UserControl.Resources>
    
    <Grid
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        RowDefinitions="*,*">
        
        <Panel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <views:TimePickerView DataContext="{Binding TimePicker}" IsVisible="{Binding IsVisible}" />
            <TextBlock
                Text="{Binding Countdown, Converter={StaticResource TimeSpanConverter}}"
                IsVisible="{Binding CountdownVisible}"
                Height="126"
                FontSize="160"
                FontFamily="{StaticResource LcdFont}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Panel>

        <Button Grid.Row="1" Padding="0,-8,0,8" Command="{Binding ChangeState}" HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock Text="{Binding State, Converter={StaticResource StateTextConverter}}" FontSize="96" LineHeight="96" FontFamily="{StaticResource LcdFont}"/>
        </Button>
        
    </Grid>
</UserControl>
