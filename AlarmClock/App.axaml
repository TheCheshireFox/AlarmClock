<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AlarmClock.App">
    <Application.Styles>
        <SimpleTheme/>
        
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="Background" Value="black" />
            <Setter Property="Foreground" Value="white" />
        </Style>
        
        <Style Selector=":is(UserControl)">
            <Setter Property="Background" Value="black" />
            <Setter Property="Foreground" Value="white" />
        </Style>
        
        <Style Selector="Button">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <StyleInclude Source="avares://AlarmClock/Styles/ComboBox.axaml"/>
    </Application.Styles>
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AlarmClock/Styles/ComboBox.Brushes.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <FontFamily x:Key="LcdFont">avares://AlarmClock/Assets/Fonts#Digital-7 Mono</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
