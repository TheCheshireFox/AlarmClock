<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AlarmClock.Components.NumberPicker">
    <UserControl.GestureRecognizers>
        <ScrollGestureRecognizer CanHorizontallyScroll="False" CanVerticallyScroll="True" IsScrollInertiaEnabled="True" ScrollStartDistance="5"/>
    </UserControl.GestureRecognizers>
    <TextBlock Name="TextBlock"
               Height="{Binding $parent[UserControl].ContentHeight}"
               LineHeight="{Binding $parent[UserControl].ContentHeight}"
               Text="{Binding $parent[UserControl].SelectedItemText}">
    </TextBlock>
</UserControl>
