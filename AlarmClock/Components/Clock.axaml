<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="672" d:DesignHeight="450"
             x:Class="AlarmClock.Components.Clock">
    <Grid
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        RowDefinitions="100,*,*"
        ColumnDefinitions="*">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" FlowDirection="RightToLeft" Width="{Binding #TimeText.Bounds.Width}" Spacing="10">
            <TextBlock Name="Temperature" FontSize="64" FontFamily="{StaticResource LcdFont}" VerticalAlignment="Bottom" d:Text="17.7°C"></TextBlock>
            <Svg Name="WeatherIcon" Path="{Binding $parent[UserControl].WeatherIconPath}" Height="38" Width="38" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,18" />
        </StackPanel>

        <TextBlock Grid.Row="1" Name="TimeText" FontSize="160" FontFamily="{StaticResource LcdFont}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
        <TextBlock Grid.Row="2" Name="DateText" FontSize="96" FontFamily="{StaticResource LcdFont}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
    </Grid>
</UserControl>
