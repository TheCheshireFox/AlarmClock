<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AlarmClock.Components.RightNavBar">
    <Grid
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        RowDefinitions="*,*,*,*"
        ColumnDefinitions="*,10">
        
        <Image Grid.Row="0" Grid.Column="0" Name="RadioButton" Source="{SvgImage /Assets/Images/radio.svg}" Tapped="RadioButton_OnTapped" />
        <Image Grid.Row="1" Grid.Column="0" Width="{Binding #RadioButton.Width}" Height="{Binding #RadioButton.Height}" />
        <Image Grid.Row="2" Grid.Column="0" Width="{Binding #RadioButton.Width}" Height="{Binding #RadioButton.Height}" />
        <Image Grid.Row="3" Grid.Column="0" Width="{Binding #RadioButton.Width}" Height="{Binding #RadioButton.Height}" />
        
    </Grid>
</UserControl>
