<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:AlarmClock.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AlarmClock.Components.TimePicker">
    <Grid ColumnDefinitions="*,80,*" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
        <components:NumberPicker Grid.Column="0"
                                 Name="HoursPicker"
                                 Min="0"
                                 Max="23"
                                 ContentHeight="160"
                                 FontSize="160"
                                 FontFamily="{StaticResource LcdFont}"
                                 HorizontalAlignment="Right"/>
        
        <TextBlock Grid.Column="1"
                   Height="160" 
                   LineHeight="160" 
                   FontSize="160" 
                   FontFamily="{StaticResource LcdFont}" 
                   HorizontalAlignment="Center">:</TextBlock>
        
        <components:NumberPicker Grid.Column="2"
                                 Name="MinutesPicker" 
                                 Min="0"
                                 Max="59"
                                 ContentHeight="160"
                                 FontSize="160"
                                 FontFamily="{StaticResource LcdFont}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"/>
    </Grid>
</UserControl>
